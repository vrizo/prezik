{
  "compilerOptions": {
    "target": "ES2023",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "types": ["node"],
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "verbatimModuleSyntax": false,
    // TS7 resolves these relative to this file's directory (no baseUrl).
    "paths": {
      "@prezik/shared": ["../shared/src/index.ts"],
      "@prezik/shared/logger": ["../shared/src/logger.ts"]
    }
  },
  "include": ["src", "test", "fixtures"],
  // worker.ts targets the Cloudflare Workers runtime; wrangler types + bundles it
  // at deploy. It is out of scope for the Node typecheck (no workers-types here).
  "exclude": ["src/worker.ts"]
}
